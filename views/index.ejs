<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travel Planner - AI Itinerary Assistant</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <header>
        <h1>Travel Planner</h1>
        <p>Your AI-powered personalized itinerary assistant</p>
    </header>

    <main>
        <section class="form-container">
            <form action="generate" method="POST">
                <div class="form-group">
                    <label for="destination">Where do you want to go?</label>
                    <input type="text" id="destination" name="destination" placeholder="e.g. Tokyo, Japan" required>
                </div>
                <div class="form-group">
                    <label for="duration">How many days?</label>
                    <input type="number" id="duration" name="duration" min="1" max="14" value="3" required>
                </div>
                <div class="form-group">
                    <label for="interests">What are your interests?</label>
                    <input type="text" id="interests" name="interests" placeholder="e.g. food, history, nature, shopping">
                </div>
                <div class="form-group">
                    <label for="budget">Budget Level</label>
                    <select name="budget" id="budget">
                        <option value="economy">Economy</option>
                        <option value="standard" selected>Standard</option>
                        <option value="luxury">Luxury</option>
                    </select>
                </div>
                <button type="submit">Generate Itinerary</button>
            </form>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Travel Planner Assistant</p>
    </footer>
</body>
</html>
